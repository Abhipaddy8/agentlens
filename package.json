  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1005.0",
    "@aws-sdk/lib-dynamodb": "^3.1005.0",
    "dotenv": "^17.3.1",
    "npc-guide": "file:../npc-guide-ai/packages/core",
    "npc-guide-ai": "file:../npc-guide-ai",
    "openai": "^6.27.0",
    "uuid": "^13.0.0"
  }
}
