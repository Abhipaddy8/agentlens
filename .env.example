# ===========================================
# AgentLens — Environment Variables
# ===========================================

# Required
OPENAI_API_KEY=sk-...

# Optional — local dev
DYNAMO_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
PORT=3100

# Upstream LLM provider (default: OpenAI)
UPSTREAM_BASE=https://api.openai.com

# Rate limiting — default RPM per agent
DEFAULT_RPM=60

# Cache TTL in hours (default: 24)
CACHE_TTL_HOURS=24

# Table names (defaults shown — CloudFormation overrides these)
TABLE_CALLS=agentlens-calls
TABLE_BUDGETS=agentlens-budgets
TABLE_CACHE=agentlens-cache
TABLE_CONTROLS=agentlens-controls
TABLE_AGENTS=agentlens-agents
TABLE_VERSIONS=agentlens-prompt-versions
